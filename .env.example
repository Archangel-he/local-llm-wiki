APP_ENV=local
PUBLIC_BASE_URL=http://localhost:8000
DATABASE_URL=postgresql+psycopg://wiki:wiki@postgres:5432/wiki
REDIS_URL=redis://redis:6379/0
RQ_QUEUE_NAME=default
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/app/storage
LLM_PROVIDER=ollama
LLM_BASE_URL=http://host.docker.internal:11434
LLM_MODEL=
DEFAULT_USER_EMAIL=default-user@local.invalid
DEFAULT_USER_DISPLAY_NAME=Default User
DEFAULT_WORKSPACE_NAME=Default Workspace
DEFAULT_WORKSPACE_SLUG=default
DEFAULT_LLM_PROFILE_KEY=mock-default
MAC_QWEN36_ENABLED=false
MAC_QWEN36_BASE_URL=http://host.docker.internal:30000/v1
MAC_QWEN36_MODEL=qwen36-aggressive-q4km
SPARK_QWEN36_ENABLED=false
SPARK_QWEN36_BASE_URL=http://spark-tunnel:30000/v1
SPARK_QWEN36_MODEL=qwen36-aggressive-q4km
MAX_UPLOAD_MB=10
JOB_MAX_ATTEMPTS=3
LLM_CONNECT_TIMEOUT_SECONDS=5
LLM_REQUEST_TIMEOUT_SECONDS=120
MODEL_ENDPOINT_ALLOWLIST=host.docker.internal,localhost,127.0.0.1,::1
INGEST_MAX_SOURCE_CHARS=120000
INGEST_MAX_EXISTING_PAGES=200
INGEST_PROMPT_VERSION=mvp1-ingest-v1
# URL-safe Base64 for exactly 32 random bytes; required before saving API keys.
MODEL_CREDENTIAL_KEY=
MODEL_CREDENTIAL_KEY_VERSION=1
SESSION_SECRET=change-me-in-production
